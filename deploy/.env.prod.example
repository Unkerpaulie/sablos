# Copy to .env at the repo root on the server and fill in real values.
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_SECRET_KEY=generate-a-50-char-random-string-here
DJANGO_ALLOWED_HOSTS=sablos.devs.tt
DJANGO_MEDIA_ROOT=/var/www/sablos_root/media
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SECURE_HSTS_SECONDS=3600

# GitHub webhook secret — must match the value set in GitHub → Settings → Webhooks.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
GITHUB_WEBHOOK_SECRET=generate-a-random-hex-secret-here
