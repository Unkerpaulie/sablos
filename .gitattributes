# Normalize line endings on commit; check out as LF everywhere.
# This prevents Windows CRLF from polluting commits and avoids the
# "uncommitted changes" trap on the Linux server when git/the OS
# rewrites EOLs on disk.
* text=auto eol=lf

# --- Source code (force LF) ---
*.py        text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.js        text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.ini       text eol=lf
*.cfg       text eol=lf

# --- Deployment artifacts (LF — they run on Linux) ---
*.sh        text eol=lf
*.conf      text eol=lf
*.service   text eol=lf
.env*       text eol=lf
Dockerfile  text eol=lf

# --- Windows-only files (keep CRLF if any are ever added) ---
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# --- Binary (never touched) ---
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       text eol=lf
*.webp      binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tar       binary
*.sqlite3   binary
*.db        binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.otf       binary
